# Copy to .env and fill in. Two profiles are shown; pick one.

# ── Self-host profile (default): SQLite + local email/password ──────────────
DB_DRIVER=sqlite
AUTH_PROVIDER=local-password
NEXT_PUBLIC_AUTH_PROVIDER=local-password
SQLITE_PATH=./data/artifacts.db

# Close open registration. The very first account can still be created (to bootstrap the
# admin); everyone after that is blocked. Leave unset to allow open sign-up.
# DISABLE_SIGNUP=true

# ── Self-host scale-up: Postgres instead of SQLite ──────────────────────────
# DB_DRIVER=postgres
# DATABASE_URL=postgres://user:pass@host:5432/artifacthost

# Public base URL of this instance (used to build artifact links).
APP_BASE_URL=http://localhost:3000

# Reverse proxies in front of this app. Leave unset on Vercel (the platform sets a
# trustworthy x-forwarded-for). Self-hosting behind nginx/Caddy/etc.? Set this to the number
# of proxies you run (usually 1) so a spoofed client X-Forwarded-For can't evade rate limits.
# TRUSTED_PROXY_HOPS=1

# Secrets — generate each with:  openssl rand -hex 32
# Required in production: the app fails to start (AUTH_SECRET/COOKIE_SECRET) rather than
# falling back to an insecure default.
AUTH_SECRET=
COOKIE_SECRET=
CRON_SECRET=

# ── Optional: company Google Workspace (OIDC) instead of local-password ─────
# AUTH_PROVIDER=oidc
# NEXT_PUBLIC_AUTH_PROVIDER=oidc
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=http://localhost:3000/api/auth/oidc/callback  # defaults to APP_BASE_URL + this path
# ALLOWED_EMAIL_DOMAINS=intezer.com   # comma-separated; verified email domain must match
# NEXT_PUBLIC_OIDC_LABEL=Google       # sign-in button label ("Continue with Google")

# ── Cloud profile: Supabase (Postgres + Supabase Auth) ──────────────────────
# DB_DRIVER=supabase
# AUTH_PROVIDER=supabase
# NEXT_PUBLIC_AUTH_PROVIDER=supabase
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
