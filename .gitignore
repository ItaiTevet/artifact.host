# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# self-host SQLite data
/data

# playwright
/test-results
/playwright-report
/e2e-browser/.cache

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Superpowers brainstorming companion (local mockups/state)
.superpowers/

# Playwright MCP artifacts
.playwright-mcp/

# local dev/smoke logs
.dev.log
.smoke.log

# local visual-review artifacts (screenshots, seed scripts)
/review-screenshots
